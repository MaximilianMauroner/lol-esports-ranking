{
  "name": "lol-esports-power-index",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.16.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run typecheck && pnpm run bundle",
    "bundle": "vite build && node scripts/check-bundle-size.mjs",
    "start": "node scripts/railway-server.mjs",
    "data:build": "tsx scripts/build-static-snapshot.ts --output data/derived/ranking-snapshot.full.json --public-data-dir public/data",
    "data:download": "node scripts/download-local-data.mjs",
    "data:crunch": "tsx scripts/build-static-snapshot.ts --output data/derived/ranking-snapshot.full.json --public-data-dir public/data --manifest data/raw/manifest.json",
    "data:refresh": "tsx scripts/refresh-data-if-changed.mjs",
    "data:build:oracle": "tsx scripts/build-static-snapshot.ts --output data/derived/ranking-snapshot.full.json --public-data-dir public/data --oracle-csv",
    "data:build:leaguepedia": "tsx scripts/build-static-snapshot.ts --output data/derived/ranking-snapshot.full.json --public-data-dir public/data --leaguepedia-json",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "tsx --test tests/**/*.test.ts",
    "benchmark:riot-gpr": "tsx scripts/compare-riot-gpr.ts",
    "benchmark:incremental": "node --expose-gc --import tsx scripts/benchmark-incremental-ranking.ts",
    "benchmark:incremental:smoke": "node --expose-gc --import tsx scripts/benchmark-incremental-ranking.ts --smoke",
    "benchmark:player-memory": "node --expose-gc --import tsx scripts/benchmark-incremental-ranking.ts --player-memory-profile",
    "benchmark:incremental:gate": "node --expose-gc --import tsx scripts/benchmark-incremental-ranking.ts --enforce-targets",
    "release:check": "pnpm run data:crunch && pnpm test && pnpm run typecheck && pnpm run lint && pnpm run benchmark:incremental:gate && pnpm run build",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm test",
    "railway:build": "pnpm run verify && pnpm run bundle",
    "preview": "vite preview",
    "railway:start": "node scripts/railway-server.mjs",
    "railway:refresh": "node scripts/run-refresh-worker.mjs",
    "railway:refresh-once": "node scripts/refresh-once.mjs",
    "fetch:lolesports": "node scripts/fetch-lolesports-schedule.mjs",
    "fetch:leaguepedia": "node scripts/fetch-leaguepedia.mjs",
    "fetch:riot-gpr": "node scripts/fetch-riot-gpr-snapshot.mjs",
    "bucket:gc": "node scripts/ranking-bucket-gc.mjs",
    "rollout:evidence": "node scripts/rollout-evidence.mjs",
    "rollout:implementation-evidence": "node scripts/rollout-implementation-evidence.mjs",
    "rollout:shadow-gate": "node scripts/rollout-shadow-gate.mjs",
    "rollout:gate": "node scripts/validate-rollout-gate.mjs",
    "rollout:cost": "node scripts/railway-cost-report.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1092.0",
    "@aws-sdk/s3-request-presigner": "^3.1092.0",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.25.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "recharts": "^3.10.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5"
  }
}
