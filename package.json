{
  "name": "lol-esports-power-index",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "node scripts/railway-server.mjs",
    "data:build": "tsx scripts/build-static-snapshot.ts --output data/derived/ranking-snapshot.full.json --public-data-dir public/data",
    "data:download": "node scripts/download-local-data.mjs",
    "data:crunch": "tsx scripts/build-static-snapshot.ts --output data/derived/ranking-snapshot.full.json --public-data-dir public/data --manifest data/raw/manifest.json",
    "data:refresh": "node scripts/refresh-data-if-changed.mjs",
    "data:build:oracle": "tsx scripts/build-static-snapshot.ts --output data/derived/ranking-snapshot.full.json --public-data-dir public/data --oracle-csv",
    "data:build:leaguepedia": "tsx scripts/build-static-snapshot.ts --output data/derived/ranking-snapshot.full.json --public-data-dir public/data --leaguepedia-json",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "tsx --test tests/**/*.test.ts",
    "benchmark:riot-gpr": "tsx scripts/compare-riot-gpr.ts",
    "release:check": "pnpm run data:crunch && pnpm test && pnpm run typecheck && pnpm run lint && pnpm run build",
    "railway:build": "pnpm run typecheck && pnpm run lint && pnpm test && pnpm run build",
    "preview": "vite preview",
    "railway:start": "node scripts/railway-server.mjs",
    "railway:refresh": "node scripts/refresh-data-if-changed.mjs",
    "fetch:lolesports": "node scripts/fetch-lolesports-schedule.mjs",
    "fetch:leaguepedia": "node scripts/fetch-leaguepedia.mjs",
    "fetch:riot-gpr": "node scripts/fetch-riot-gpr-snapshot.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@vercel/blob": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
