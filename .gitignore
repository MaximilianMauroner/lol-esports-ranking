# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Local data inputs/caches. Fetch/update into data/raw locally, but do not
# commit provider downloads; commit only the manifest that documents inputs.
data/*.json
data/*.csv
data/raw/**
!data/raw/
!data/raw/manifest.json
data/derived/**
data/**/*.csv
data/**/*.jsonl
data/**/*.ndjson
data/**/*.parquet
data/**/*.sqlite
data/**/*.db
!data/README.md

# Commit the generated client payload from data:crunch:
# public/data/ranking-summary.json
# public/data/players.json
# public/data/team-history.json
# public/data/snapshots/*.json
!public/data/
!public/data/ranking-summary.json
!public/data/players.json
!public/data/team-history.json
!public/data/snapshots/
!public/data/snapshots/*.json

# Do not ship/re-add full public snapshots; they can exceed GitHub limits.
public/data/ranking-snapshot.json
public/data/ranking-snapshot.full.json
public/data/*.full.json
public/data/**/*.tmp

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
