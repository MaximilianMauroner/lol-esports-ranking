# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.ranking-crunch/

# Local data inputs/caches. Fetch/update into data/raw locally, but do not
# commit provider downloads; commit only the manifest that documents inputs.
data/*.json
data/*.csv
data/raw/**
!data/raw/
!data/raw/manifest.json
data/derived/**
data/**/*.csv
data/**/*.jsonl
data/**/*.ndjson
data/**/*.parquet
data/**/*.sqlite
data/**/*.db
!data/README.md

# Generated browser payloads are deploy artifacts. Railway stores them in the
# private bucket; static hosts may materialize an ignored public/data tree.
.generated/
public/data/**

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
