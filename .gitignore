# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Local data inputs/caches. Fetch/update into data/raw locally, but do not
# commit provider downloads; commit only the manifest that documents inputs.
data/*.json
data/*.csv
data/raw/**
!data/raw/
!data/raw/manifest.json
data/derived/**
data/**/*.csv
data/**/*.jsonl
data/**/*.ndjson
data/**/*.parquet
data/**/*.sqlite
data/**/*.db
!data/README.md

# Commit only the compact browser payload from data:crunch. Railway uploads
# the same payload to Bucket storage, plus larger audit artifacts that should
# stay out of Git.
public/data/**
!public/data/
!public/data/ranking-summary.json
!public/data/entities/
!public/data/entities/*.json
!public/data/history/
!public/data/history/region-series.json
!public/data/history/team-series/
!public/data/history/team-series/*.json
!public/data/scopes/
!public/data/scopes/*.json

# Do not ship/re-add full public snapshots; they can exceed GitHub limits.
public/data/ranking-snapshot.json
public/data/ranking-snapshot.full.json
public/data/*.full.json
public/data/**/*.tmp

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
